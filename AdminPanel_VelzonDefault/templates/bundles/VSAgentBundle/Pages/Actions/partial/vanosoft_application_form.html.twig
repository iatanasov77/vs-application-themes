{{ form_start(virtualhostForm, { 'attr': { 'class': 'form-horizontal' } }) }}
    <div class="row g-3">
        <div class="col-lg-12">
            {{ form_label(virtualhostForm.virtualHost, null, {
                'label_attr': {'class': 'form-label'}
                }) 
            }}
            
            {{ form_widget(virtualhostForm.virtualHost, {'attr': {'class': 'form-control'}}) }}
            
            <div class="form-text">
                {{ 'vs_agent.form.virtual_host.virtual_host_help' | trans( {},'VSAgentBundle' ) }}
            </div>
        </div>
        <!--end col-->
        
        <div class="col-lg-12">
            {{ form_label(virtualhostForm.apacheService, null, {
                'label_attr': {'class': 'form-label'}
                }) 
            }}
            
            {{ form_widget(virtualhostForm.apacheService, {'attr': {'class': 'form-control'}}) }}
        </div>
        <!--end col-->
        
        <div class="mt-4">
            <div class="hstack gap-2 justify-content-end">
                <button type="button" class="btn btn-light" data-bs-dismiss="modal">
                    {{ 'vs_application.form.close' | trans( {},'VSApplicationBundle' ) }}
                </button>
                <button type="button" class="btn btn-success" id="btnShowBrokenVirtualHost">
                    {{ 'vs_agent.form.virtual_host.show_broken' | trans( {},'VSAgentBundle' ) }}
                </button>
                <button type="button" class="btn btn-success" id="btnBrokeVirtualHost">
                    {{ 'vs_agent.form.virtual_host.broke' | trans( {},'VSAgentBundle' ) }}
                </button>
            </div>
        </div>
        <!--end col-->
    </div>
    <!--end row-->
{{ form_end(virtualhostForm, {'render_rest': false}) }}