{{ form_start(virtualhostForm, { 'attr': { 'class': 'form-horizontal' } }) }}
    <div class="row g-3">
        <div class="col-lg-12">
            {{ form_label(vankosoftApplicationForm.application, null, {
                'label_attr': {'class': 'form-label'}
                }) 
            }}
            
            {{ form_widget(vankosoftApplicationForm.application, {'attr': {'class': 'form-control'}}) }}
        </div>
        <!--end col-->
        
        <div class="mt-4">
            <div class="hstack gap-2 justify-content-end">
                <button type="button" class="btn btn-light" data-bs-dismiss="modal">
                    {{ 'vs_application.form.close' | trans( {},'VSApplicationBundle' ) }}
                </button>
                <button type="button" class="btn btn-success" id="btnDeleteApplication">
                    {{ 'vs_agent.form.vankosoft_application.delete' | trans( {},'VSAgentBundle' ) }}
                </button>
            </div>
        </div>
        <!--end col-->
    </div>
    <!--end row-->
{{ form_end(virtualhostForm, {'render_rest': false}) }}